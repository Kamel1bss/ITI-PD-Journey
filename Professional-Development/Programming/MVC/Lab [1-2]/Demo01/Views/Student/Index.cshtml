@model IEnumerable<Student> // readonly

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">Students</h2>

        <a asp-action="create" class="btn btn-success px-4 shadow-sm">
            + Create
        </a>
    </div>

    <div class="card border-0 shadow">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-secondary text-center">
                    <tr>
                        <th>Id</th>
                        <th>Name</th>
                        <th>Age</th>
                        <th>Department</th>
                        <th style="width:25%">Action</th>
                    </tr>
                </thead>

                <tbody class="text-center">

                    @if (Model == null || Model.Count() == 0)
                    {
                        <tr>
                            <td colspan="5" class="py-4 text-muted">
                                No students found.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var Student in Model)
                        {
                            <tr>

                                <td class="fw-semibold text-primary">
                                    @Student.Id
                                </td>

                                <td class="fw-bold">
                                    @Student.Name
                                </td>

                                <td>
                                    @Student.Age
                                </td>

                                <td>
                                    <span class="badge bg-info text-dark px-3 py-2">
                                        @Student.Department?.DeptName
                                    </span>
                                </td>

                                <td>
                                    <div class="d-flex justify-content-center gap-2">

                                        <a asp-action="Details"
                                            asp-route-id="@Student.Id"
                                            class="btn btn-sm btn-outline-info">
                                            Details
                                        </a>

                                        <a asp-action="Edit"
                                            asp-route-id="@Student.Id"
                                            class="btn btn-sm btn-outline-warning">
                                            Edit
                                        </a>

                                        <a asp-action="Delete"
                                            asp-route-id="@Student.Id"
                                            class="btn btn-sm btn-outline-danger">
                                            Delete
                                        </a>

                                    </div>
                                </td>

                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
