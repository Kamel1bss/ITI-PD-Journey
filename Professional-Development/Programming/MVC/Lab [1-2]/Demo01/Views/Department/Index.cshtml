@model IEnumerable<Department> // readonly

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">Departments</h2>

        <a asp-action="create" class="btn btn-success px-4 shadow-sm">
            + Create
        </a>
    </div>

    <div class="card border-0 shadow">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-secondary text-center">
                    <tr>
                        <th>Id</th>
                        <th>Name</th>
                        <th>Capacity</th>
                        <th style="width:35%">Action</th>
                    </tr>
                </thead>

                <tbody class="text-center">

                    @if (Model == null || Model.Count() == 0)
                    {
                        <tr>
                            <td colspan="4" class="py-4 text-muted">
                                No departments found.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var department in Model)
                        {
                            <tr>

                                <td class="fw-semibold text-primary">
                                    @department.DeptId
                                </td>

                                <td class="fw-bold">
                                    @department.DeptName
                                </td>

                                <td>
                                    <span class="badge bg-info text-dark px-3 py-2">
                                        @department.Capacity
                                    </span>
                                </td>

                                <td>
                                    <div class="d-flex flex-wrap justify-content-center gap-2">

                                        <a asp-action="Details"
                                           asp-route-id="@department.DeptId"
                                           class="btn btn-sm btn-outline-info">
                                            Details
                                        </a>

                                        <a asp-action="Edit"
                                           asp-route-id="@department.DeptId"
                                           class="btn btn-sm btn-outline-warning">
                                            Edit
                                        </a>

                                        <a asp-action="Delete"
                                           asp-route-id="@department.DeptId"
                                           class="btn btn-sm btn-outline-danger">
                                            Delete
                                        </a>

                                        <a asp-action="ShowCourses"
                                           asp-route-id="@department.DeptId"
                                           class="btn btn-sm btn-outline-secondary">
                                            Show Courses
                                        </a>

                                        <a asp-action="ManageDeptCourses"
                                           asp-route-id="@department.DeptId"
                                           class="btn btn-sm btn-dark">
                                            Manage Courses
                                        </a>

                                    </div>
                                </td>

                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>