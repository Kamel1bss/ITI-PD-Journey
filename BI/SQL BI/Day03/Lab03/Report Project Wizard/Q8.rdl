  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>ITI_DS</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>ea525563-784d-4b14-bf16-ad7779cf26b6</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Students">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@DeptId">
            <Value>=Parameters!DeptId.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
    s.St_Id,
    s.St_Fname,
    s.St_Lname,
    s.St_Address,
    s.St_Age,
    s.Dept_Id,
    d.Dept_Name
FROM Student s
INNER JOIN Department d 
    ON s.Dept_Id = d.Dept_Id
WHERE s.Dept_Id IN (@DeptId)</CommandText>
      </Query>
      <Fields>
        <Field Name="St_Id">
          <DataField>St_Id</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="St_Fname">
          <DataField>St_Fname</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="St_Lname">
          <DataField>St_Lname</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="St_Address">
          <DataField>St_Address</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="St_Age">
          <DataField>St_Age</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Dept_Id">
          <DataField>Dept_Id</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Dept_Name">
          <DataField>Dept_Name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Departments">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT 
    Dept_Id,
    Dept_Name
FROM Department</CommandText>
      </Query>
      <Fields>
