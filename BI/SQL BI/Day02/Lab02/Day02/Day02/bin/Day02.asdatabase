      <MdxScripts>
        <MdxScript>
          <ID>MdxScript</ID>
          <Name>MdxScript</Name>
          <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
          <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
          <Commands>
            <Command>
              <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
*/
CALCULATE;

CREATE MEMBER CURRENTCUBE.[Measures].[Customer_cnt]
  AS DISTINCTCOUNT([Customer Dim 1].[Customer ID].Members),
  FORMAT_STRING = '#,##0',
  VISIBLE = 1;

CREATE MEMBER CURRENTCUBE.[Measures].[Product_cnt]
  AS DISTINCTCOUNT([Product Dim 2].[Product ID].Members),
  FORMAT_STRING = '#,##0',
  VISIBLE = 1;

CREATE MEMBER CURRENTCUBE.[Measures].[Salesman_cnt]
  AS DISTINCTCOUNT([Salesman Dim].[Salesman ID].Members),
  FORMAT_STRING = '#,##0',
  VISIBLE = 1;

CREATE MEMBER CURRENTCUBE.[Measures].[Channel_cnt]
  AS DISTINCTCOUNT([Channel Dim].[Channal ID].Members),
  FORMAT_STRING = '#,##0',
  VISIBLE = 1;</Text>
            </Command>
          </Commands>
        </MdxScript>
      </MdxScripts>
