          <Name>QtyKPI</Name>
          <Value>[Measures].[Qty]</Value>
          <Goal>1000</Goal>
          <Status>case
    when kpivalue("QtyKPI") &gt; 1000 then 1
    when kpivalue("QtyKPI") &lt; 1000 then -1 
    else 0
end</Status>
          <Trend></Trend>
          <TrendGraphic>Standard Arrow</TrendGraphic>
          <StatusGraphic>Gauge - Ascending</StatusGraphic>
        </Kpi>
